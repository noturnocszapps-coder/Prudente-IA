rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'contato.fh3@gmail.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'contato.fh3@gmail.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'isVip', 'createdAt', 'referralCode', 'referralCount', 'firstPaymentCompleted', 'commissionGenerated', 'totalEarnings']) 
        && data.keys().size() >= 10
        && data.uid is string && data.uid == request.auth.uid
        && data.email is string && data.email == request.auth.token.email
        && data.role in ['user', 'vip', 'admin']
        && data.isVip is bool
        && data.createdAt == request.time
        && data.referralCode is string
        && data.referralCount is number;
    }

    function isValidReferral(data) {
      return data.keys().hasAll(['referrerId', 'refereeId', 'createdAt'])
        && data.keys().size() == 3
        && data.referrerId is string
        && data.refereeId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidAlert(data) {
      return data.keys().hasAll(['title', 'description', 'severity', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.severity in ['info', 'warning', 'alert']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidDailyTip(data) {
      return data.keys().hasAll(['title', 'content', 'type', 'date'])
        && data.keys().size() == 4
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 2000
        && data.type in ['economy', 'leisure', 'reminder']
        && data.date is string;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'image', 'price', 'affiliateLink', 'category', 'createdAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() <= 200
        && data.image is string
        && data.price is number
        && data.affiliateLink is string
        && data.category is string
        && data.createdAt is timestamp;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt', 'updatedAt'])
        && data.keys().size() == 4
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'timestamp'])
        && data.keys().size() == 3
        && data.role in ['user', 'assistant']
        && data.content is string && data.content.size() <= 4000
        && data.timestamp == request.time;
    }

    // Phase 4: Match Blocks

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if (isSignedIn() && request.query.limit <= 1) || isAdmin();
      allow create: if isEmailVerified() && isValidUser(incoming()) 
        && incoming().role == 'user' 
        && incoming().isVip == false 
        && incoming().referralCount == 0
        && incoming().firstPaymentCompleted == false
        && incoming().commissionGenerated == false;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'firstPaymentCompleted', 'referralCode', 'referralCount', 'commissionGenerated', 'totalEarnings'])
        )) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['referralCount']) && incoming().referralCount == existing().referralCount + 1) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // REFERRALS
    match /referrals/{referralId} {
      allow read: if isSignedIn() && (resource.data.referrerId == request.auth.uid || resource.data.refereeId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidReferral(incoming());
    }

    // ADMINS (Secure reference for role check)
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Managed manually or via cloud console
    }

    // ALERTS
    match /alerts/{alertId} {
      allow read: if true;
      allow write: if isAdmin() && isValidAlert(incoming());
    }

    // DAILY TIPS
    match /dailyTips/{tipId} {
      allow read: if true;
      allow write: if isAdmin() && isValidDailyTip(incoming());
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    // CHATS
    match /chats/{chatId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isEmailVerified() && isValidChat(incoming());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'title', 'userId', 'createdAt'])
        && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isEmailVerified() && isValidMessage(incoming()) && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
      }
    }
  }
}
