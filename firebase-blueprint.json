{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "vip", "admin"] },
        "isVip": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "referralCount": { "type": "number" },
        "firstPaymentCompleted": { "type": "boolean" },
        "commissionGenerated": { "type": "boolean" },
        "totalEarnings": { "type": "number" }
      },
      "required": ["uid", "email", "role", "referralCode"]
    },
    "Referral": {
      "title": "Referral Record",
      "description": "Tracks who invited whom",
      "type": "object",
      "properties": {
        "referrerId": { "type": "string" },
        "refereeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["referrerId", "refereeId", "createdAt"]
    },
    "Alert": {
      "title": "City Alert",
      "description": "Important alerts for the city",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "alert"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "severity", "createdAt"]
    },
    "DailyTip": {
      "title": "Daily Tip",
      "description": "Tips for economy, leisure, or important reminders",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["economy", "leisure", "reminder"] },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["title", "content", "type", "date"]
    },
    "Product": {
      "title": "Affiliate Product",
      "description": "Products with affiliate links",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "price": { "type": "number" },
        "affiliateLink": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "affiliateLink", "price"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Root session for AI chat",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "Individual messages in a chat session",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Profile for each user"
    },
    "alerts/{alertId}": {
      "schema": "Alert",
      "description": "Global city alerts managed by admin"
    },
    "dailyTips/{tipId}": {
      "schema": "DailyTip",
      "description": "Daily content managed by admin"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Affiliate products managed by admin"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "User chat sessions"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a session"
    },
    "referrals/{referralId}": {
      "schema": "Referral",
      "description": "Referral connections"
    }
  }
}
